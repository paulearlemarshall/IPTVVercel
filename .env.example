# Neon / PostgreSQL connection string used by Drizzle and all API routes.
DATABASE_URL=postgres://user:password@host/neondb?sslmode=require

# Xtream Codes credentials. These are the runtime source of truth: they are
# resolved per request and are NOT persisted in the database. Required.
XC_USERNAME=your_username
XC_PASSWORD=your_password

# Provider base URLs. XC_SERVER_1 is required (seeds the default profile).
# Add XC_SERVER_2 .. XC_SERVER_10 for additional selectable endpoints.
XC_SERVER_1=https://example-iptv-server.test

# Optional: catalogue cache freshness in milliseconds (default 86400000 = 24h).
# Cached categories/streams/metadata older than this are re-fetched on access.
# XC_DB_CACHE_TTL_MS=86400000
